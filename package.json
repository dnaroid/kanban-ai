{
	"name": "kanban-ai",
	"version": "0.1.0",
	"description": "Kanban for Headless OpenCode + oh-my-opencode",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev": "pnpm --filter @kanban-ai/next-js dev",
		"build": "pnpm --filter @kanban-ai/next-js build",
		"start": "pnpm --filter @kanban-ai/next-js start",
		"lint": "pnpm --filter @kanban-ai/next-js lint",
		"test": "vitest",
		"test:run": "vitest run"
	},
	"devDependencies": {
		"@vitejs/plugin-react": "^5.1.2",
		"jsdom": "^27.4.0",
		"vitest": "^4.0.18"
	}
}
