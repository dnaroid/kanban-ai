# API
VITE_API_URL=http://localhost:3000

# OpenCode Server
# Порт для запуска opencode serve
OPENCODE_PORT=4096

# OpenCode SDK
# URL для подключения к OpenCode серверу
OPENCODE_URL=http://localhost:4096

# Если сервер на другом порту, измените BOTH значения:
# OPENCODE_PORT=4100
# OPENCODE_URL=http://localhost:4100

# User Story Language
# Language for AI-generated user stories (titles, descriptions, acceptance criteria).
# Any ISO 639-1 language code (e.g. "en", "ru", "de", "fr", "es", "ja", "zh").
# Invalid or empty values fall back to "en".
STORY_LANGUAGE=en

# Run Session Status Mode
# Use legacy text-based status markers (__OPENCODE_STATUS__::...) in run sessions.
# Default is "0" (markerless mode — runtime state inspection only).
# Set to "1" to restore legacy text marker parsing.
RUNS_USE_TEXT_STATUS_MARKERS=0
