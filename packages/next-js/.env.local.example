NEXT_PUBLIC_API_URL=http://127.0.0.1:3000
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3100
RUNS_DEFAULT_CONCURRENCY=1
# Format: provider-or-provider:model=number,example openai=2,anthropic:claude-sonnet-4=1
RUNS_PROVIDER_CONCURRENCY=

# Enable isolated Git worktrees for regular execution runs (experimental)
RUNS_WORKTREE_ENABLED=false

# Use legacy text-based status markers (__OPENCODE_STATUS__::...) in run sessions.
# Default is "0" (markerless mode — runtime state inspection only).
# Set to "1" to restore legacy text marker parsing.
RUNS_USE_TEXT_STATUS_MARKERS=0
