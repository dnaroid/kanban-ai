{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "google_auth": false,
  "notification": {
    "force_enable": false
  },
  "disabled_mcps": [
    "websearch"
  ],
  "experimental": {
    "parallelAgentExecution": true,
    "mcp_auto_start": true
  },
  "lsp": {
    "enabled": true,
    "cacheResponses": false,
    "markdown": {
      "command": [
        "node",
        "/usr/local/lib/node_modules/vscode-langservers-extracted/bin/vscode-markdown-language-server",
        "--stdio"
      ],
      "extensions": [
        ".md",
        ".mdx"
      ]
    }
  },
  "systemDefaultModel": "zai-coding-plan/glm-5",
  "categories": {
    "visual-engineering": {
      "model": "google/antigravity-gemini-3-pro",
//      "temperature": 0.45
    },
    "artistry": {
      "model": "google/antigravity-gemini-3-pro",
//      "temperature": 0.8
    },
    "writing": {
      "model": "zai-coding-plan/glm-5",
//      "temperature": 0.35
    },
    "quick": {
      "model": "zai-coding-plan/glm-4.7",
//      "temperature": 0.2
    },
    "unspecified-high": {
      "model": "openai/gpt-5.3-codex",
//      "temperature": 0.1
    },
    "unspecified-low": {
      "model": "zai-coding-plan/glm-5",
//      "temperature": 0.25
    },
    "ultrabrain": {
      "model": "openai/gpt-5.3-codex",
//      "temperature": 0.1,
      "variant": "xhigh"
    },
    "deep": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    }
  },
  "agents": {
    "sisyphus": {
      "model": "zai-coding-plan/glm-5",
//      "temperature": 0.15,
      "reasoningEffort": "high"
    },
    "atlas": {
      "model": "zai-coding-plan/glm-5",
//      "temperature": 0.18,
      "reasoningEffort": "high"
    },
    "librarian": {
      "model": "zai-coding-plan/glm-5",
//      "temperature": 0.08
    },
    "explore": {
      "model": "zai-coding-plan/glm-4.5-air",
//      "temperature": 0.12
    },
    "oracle": {
      "model": "openai/gpt-5.2",
//      "temperature": 0.12,
      "reasoningEffort": "high",
      "variant": "high"
    },
    "multimodal-looker": {
      "model": "zai-coding-plan/glm-4.6v",
//      "temperature": 0.2
    },
    "metis": {
      "model": "openai/gpt-5.2",
//      "temperature": 0.08,
      "reasoningEffort": "high",
      "variant": "max"
    },
    "momus": {
      "model": "openai/gpt-5.2",
//      "temperature": 0.08,
      "reasoningEffort": "high",
      "variant": "medium"
    },
    "prometheus": {
      "model": "openai/gpt-5.2",
      "reasoningEffort": "high",
      "variant": "max"
    }
  },
  "background_task": {
    "defaultConcurrency": 5,
    "providerConcurrency": {
      "anthropic": 3,
      "openai": 5,
      "google": 10,
      "zai-coding-plan": 3,
      "chatgpt-proxy": 1
    },
    "modelConcurrency": {
      "anthropic/claude-opus-4-5": 2,
      "anthropic/claude-sonnet-4-5": 3,
      "openai/gpt-5.3": 5,
      "openai/gpt-5.2": 5,
      "openai/gpt-5.2-codex": 3,
      "openai/gpt-5.1-codex-max": 3,
      "google/antigravity-gemini-3-pro-high": 5,
      "google/antigravity-gemini-3-pro-low": 6,
      "google/antigravity-gemini-3-flash": 10,
      "google/antigravity-gemini-3-pro": 10,
      "google/antigravity-claude-sonnet-4-5": 3,
      "google/antigravity-claude-opus-4-5": 2,
      "zai-coding-plan/glm-5": 1,
      "zai-coding-plan/glm-4.7": 3,
      "zai-coding-plan/glm-4.5-air": 3,
      "zai-coding-plan/glm-4.5-flash": 2,
      "zai-coding-plan/glm-4.6v": 1,
      "chatgpt-proxy/gpt-4": 1
    }
  }
}
